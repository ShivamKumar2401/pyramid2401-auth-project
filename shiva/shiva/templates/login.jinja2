<!DOCTYPE html>
<html>
<head>
    <title>Login</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            margin: 0;
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            font-family: 'Segoe UI', sans-serif;
            background: url("https://images.unsplash.com/photo-1521790360280-8c3a1551f7f0")
                        no-repeat center center/cover;
            position: relative;
            overflow: hidden;
        }

        /* Light overlay */
        body::before {
            content: "";
            position: absolute;
            inset: 0;
            background: rgba(255, 255, 255, 0.65);
            backdrop-filter: blur(3px);
        }

        .main-container {
            position: relative;
            z-index: 2;
            width: 900px;
            height: 550px;
            display: flex;
            border-radius: 15px;
            overflow: hidden;
            box-shadow: 0 15px 40px rgba(0,0,0,0.2);
        }

        .left-side {
            width: 45%;
            background: #1d3557;
            color: white;
            display: flex;
            justify-content: center;
            align-items: center;
            text-align: center;
            padding: 40px;
        }

        .left-side h2 {
            font-weight: 700;
        }

        .right-side {
            width: 55%;
            background: #e07a5f;
            color: white;
            padding: 50px;
        }

        .right-side h2 {
            margin-bottom: 30px;
            font-weight: 600;
            color: white;
        }

        .form-control {
            border-radius: 6px;
            margin-bottom: 20px;
        }

        .btn-custom {
            background: #1d3557;
            border: none;
            color: white;
            font-weight: 600;
        }

        .btn-custom:hover {
            background: #16324f;
        }

        .signup-link {
            margin-top: 15px;
            font-size: 14px;
        }

        .signup-link a {
            color: #1d3557;
            text-decoration: none;
            font-weight: 600;
        }

        .signup-link a:hover {
            text-decoration: underline;
        }

        /* Decorative Shapes */
        .shape1 {
            position: absolute;
            top: 60px;
            left: 80px;
            width: 120px;
            height: 120px;
            background: #f4a261;
            border-radius: 30% 70% 60% 40% / 40% 30% 70% 60%;
            opacity: 0.3;
            z-index: 1;
        }

        .shape2 {
            position: absolute;
            bottom: 80px;
            right: 120px;
            width: 150px;
            height: 150px;
            background: #1d3557;
            border-radius: 50%;
            opacity: 0.2;
            z-index: 1;
        }

    </style>
</head>

<body>

<div class="shape1"></div>
<div class="shape2"></div>

<div class="main-container">

    <!-- Left Side -->
    <div class="left-side">
        <div>
            <h2>Welcome </h2>
            <p class="mt-3">
                Login to manage your daily use products and stay organized.
            </p>
        </div>
    </div>

    <!-- Right Side -->
    <div class="right-side">

        <h2>Login</h2>

        {% if error %}
        <div class="alert alert-danger">
            {{ error }}
        </div>
        {% endif %}

        <form method="POST">

            <!-- Email -->
            <input type="email"
                   name="email"
                   class="form-control"
                   placeholder="Email Address"
                   required>

            <!-- Password -->
            <input type="password"
                   name="password"
                   class="form-control"
                   placeholder="Password"
                   required>

            <button type="submit" class="btn btn-custom w-100">
                Login
            </button>

        </form>

        <div class="signup-link">
            Don't have an account?
            <a href="{{ request.route_url('signup') }}">Create Account</a>
        </div>

    </div>

</div>

</body>
</html>
