    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Pyramid (pserve)",
            "type": "debugpy",
            "request": "launch",
            "module": "pyramid.scripts.pserve",
            "args": [
                "shiva//development.ini"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "justMyCode": false
        }
    ]
}